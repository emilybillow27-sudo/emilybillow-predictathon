###############################################
# OS / Editor junk
###############################################
.DS_Store
Thumbs.db
*.swp
*.swo

###############################################
# Python cache
###############################################
__pycache__/
*.pyc
*.pyo

###############################################
# Jupyter
###############################################
.ipynb_checkpoints/

###############################################
# Snakemake internals
###############################################
.snakemake/
*.snakemake_timestamp

###############################################
# Logs / temp files
###############################################
*.log
*.tmp
*.bak

###############################################
# Model artifacts (generated)
###############################################
trained_models/*/
!trained_models/.gitkeep

###############################################
# Results (generated predictions)
###############################################
results/*/
!results/.gitkeep

###############################################
# Predictathon submission outputs (generated)
###############################################
submission/*/
!submission/.gitkeep

###############################################
# Processed data (generated)
###############################################
data/processed/*/
!data/processed/.gitkeep

# Allow global GRM folder to be tracked if needed
!data/processed/global/
!data/processed/global/*.txt

###############################################
# Filtered VCFs (generated)
###############################################
data/predictathon/*/genotypes/*_filtered.vcf.gz
data/predictathon/*/genotypes/*_filtered.vcf.gz.tbi

###############################################
# Large intermediate genotype matrices (old pipeline)
###############################################
data/predictathon/*/processed/geno_*.npy
data/predictathon/*/processed/geno_*.csv
data/predictathon/*/processed/GRM.npy