# ----------------------------------------
# Genotype files (large, always LFS)
*.vcf filter=lfs diff=lfs merge=lfs -text
*.vcf.gz filter=lfs diff=lfs merge=lfs -text

# Large numeric arrays (always LFS)
*.npy filter=lfs diff=lfs merge=lfs -text
*.npz filter=lfs diff=lfs merge=lfs -text
# Compressed archives (always LFS)
*.gz filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
# Large model artifacts (always LFS)
*.joblib filter=lfs diff=lfs merge=lfs -text
*.pkl filter=lfs diff=lfs merge=lfs -text
# Large CSVs (optional but recommended)
# These can be 100MB–2GB depending on env matrices.
data/processed/*.csv filter=lfs diff=lfs merge=lfs -text
predictathon_submission/**/*.csv filter=lfs diff=lfs merge=lfs -text
trained_models/geno_numeric_imputed.npy !text !filter !merge !diff
trained_models/training_metadata.pkl !text !filter !merge !diff
