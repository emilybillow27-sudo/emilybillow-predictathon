flowchart TB

%% ---------------------------------------------------------
%% Phenotype lane
%% ---------------------------------------------------------
subgraph PHENO[Phenotype Processing]
    A1[Raw Phenotypes]
    A2[Harmonize and Clean]
    A3[Filter Tiny Trials]
    A4[Extract Env Covariates]
    A5[Compute Genotype BLUPs]

    A1 --> A2 --> A3 --> A4 --> A5
end

%% ---------------------------------------------------------
%% Genotype lane
%% ---------------------------------------------------------
subgraph GENO[Genotype Processing]
    B1[Raw VCFs]
    B2[Merge and QC]
    B3[Cache Genotype Matrix PKL]
    B4[Build GRM]

    B1 --> B2 --> B3 --> B4
end

%% ---------------------------------------------------------
%% Model lane
%% ---------------------------------------------------------
subgraph MODEL[Model Training]
    C1[Assemble Training Matrix]
    C2[Reaction Norm GBLUP]
    C3[Fit Final Model]

    C1 --> C2 --> C3
end

%% ---------------------------------------------------------
%% Output lane
%% ---------------------------------------------------------
subgraph OUTPUT[Outputs]
    D1[Save Model Artifacts]
    D2[GRM and Lines]
    D3[Training Metadata]

    D1 --> D2 --> D3
end

%% ---------------------------------------------------------
%% Cross lane connections
%% ---------------------------------------------------------
A5 --> C1
B4 --> C1
C3 --> D1

